{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "WiFiManager": "Debug"
    }
  },
  "WpaSupplicant": {
    "ControlSocket": "/run/wpa_supplicant/wlp0s20f3",
    "UseMock": false
  },
  "Dhcp": {
    "Enabled": true,
    "UseSudo": true,
    "Command": "dhclient",
    "Args": "-v {iface}",
    "TimeoutSeconds": 20
  },
  "Dns": {
    "Enabled": true,
    "UseSudo": true,
    "Servers": "8.8.8.8,1.1.1.1",
    "TimeoutSeconds": 10
  }
}
