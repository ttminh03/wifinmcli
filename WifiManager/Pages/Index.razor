@page "/"
@using WifiManager.Models
@using WifiManager.Services
@inject WifiManagerService WifiService
@implements IDisposable

<div class="page-container">

    <!-- ── Current connection card ─────────────────────────── -->
    @if (WifiService.CurrentConnection is { } conn)
    {
        <div class="card card-connected">
            <div class="card-header">
                <span class="card-icon">✅</span>
                <span class="card-title">Connected</span>
                <button class="btn btn-danger btn-sm" @onclick="HandleDisconnect">
                    Disconnect
                </button>
            </div>

            <div class="conn-grid">
                <div class="conn-item">
                    <div class="conn-label">SSID</div>
                    <div class="conn-value">@conn.SSID</div>
                </div>
                <div class="conn-item">
                    <div class="conn-label">BSSID</div>
                    <div class="conn-value mono">@conn.BSSID</div>
                </div>
                <div class="conn-item">
                    <div class="conn-label">IP Address</div>
                    <div class="conn-value mono">@(string.IsNullOrEmpty(conn.IPAddress) ? "—" : conn.IPAddress)</div>
                </div>
                <div class="conn-item">
                    <div class="conn-label">Frequency</div>
                    <div class="conn-value">@conn.Frequency MHz (@FrequencyBand(conn.Frequency))</div>
                </div>
                <div class="conn-item">
                    <div class="conn-label">Signal (RSSI)</div>
                    <div class="conn-value">
                        <div class="progress-bar-wrap">
                            <div class="progress-bar"
                                 style="width:@conn.RSSI%; background:@RSSIColor(conn.RSSI)">
                            </div>
                            <span class="progress-label">@conn.RSSI%</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (WifiService.IsInitialized)
    {
        <div class="card card-disconnected">
            <span class="card-icon">📵</span>
            <span>Not connected to any WiFi network.</span>
        </div>
    }

    <!-- ── Error banner ────────────────────────────────────── -->
    @if (!string.IsNullOrEmpty(WifiService.LastError))
    {
        <div class="alert alert-error">
            ⚠️ @WifiService.LastError
        </div>
    }
    @if (!string.IsNullOrEmpty(_connectError))
    {
        <div class="alert alert-error">
            ⚠️ @_connectError
        </div>
    }

    <!-- ── Scan panel ──────────────────────────────────────── -->
    <div class="card">
        <div class="card-header">
            <span class="card-icon">📡</span>
            <span class="card-title">Available Networks</span>
            <button class="btn btn-primary btn-sm"
                    @onclick="HandleScan"
                    disabled="@WifiService.IsScanning">
                @if (WifiService.IsScanning)
                {
                    <span class="spinner"></span>
                    <span>Scanning…</span>
                }
                else
                {
                    <span>🔍 Scan</span>
                }
            </button>
        </div>

        @if (!WifiService.IsInitialized)
        {
            <div class="status-msg">
                <span class="spinner"></span> Initialising DBus connection…
            </div>
        }
        else if (WifiService.IsScanning)
        {
            <div class="status-msg">
                <span class="spinner"></span> Scanning for networks…
            </div>
        }
        else if (!WifiService.AccessPoints.Any())
        {
            <div class="status-msg">
                No networks found. Press <strong>Scan</strong> to search.
            </div>
        }
        else
        {
            <!-- WiFi table -->
            <div class="table-wrapper">
                <table class="wifi-table">
                    <thead>
                        <tr>
                            <th>SSID</th>
                            <th>BSSID</th>
                            <th>Signal</th>
                            <th>Frequency</th>
                            <th>Security</th>
                            <th>Max Rate</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ap in WifiService.AccessPoints)
                        {
                            var isActive = WifiService.CurrentConnection?.SSID == ap.SSID;
                            <tr class="@(isActive ? "row-active" : "")">
                                <td>
                                    <div class="ssid-cell">
                                        <span class="wifi-icon">@WifiIcon(ap.RSSI)</span>
                                        <span>@ap.SSID</span>
                                        @if (isActive)
                                        {
                                            <span class="badge-connected">✓ Connected</span>
                                        }
                                    </div>
                                </td>
                                <td class="mono text-muted">@ap.BSSID</td>
                                <td>
                                    <div class="rssi-cell">
                                        <div class="progress-bar-wrap small">
                                            <div class="progress-bar"
                                                 style="width:@ap.RSSI%; background:@RSSIColor(ap.RSSI)">
                                            </div>
                                        </div>
                                        <span class="rssi-val" style="color:@RSSIColor(ap.RSSI)">
                                            @ap.RSSI%
                                        </span>
                                    </div>
                                </td>
                                <td>@ap.Frequency MHz<br /><span class="text-muted small">@ap.FrequencyBand</span></td>
                                <td>
                                    <span class="badge @SecurityBadgeClass(ap.Security)">
                                        @ap.Security
                                    </span>
                                </td>
                                <td class="text-muted">@ap.MaxBitrate Mbps</td>
                                <td>
                                    @if (isActive)
                                    {
                                        <button class="btn btn-danger btn-xs"
                                                @onclick="HandleDisconnect">
                                            Disconnect
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-primary btn-xs"
                                                @onclick="() => ShowConnectForm(ap)"
                                                disabled="@WifiService.IsConnecting">
                                            Connect
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="table-footer">
                @WifiService.AccessPoints.Count network(s) found
            </div>
        }
    </div>

</div>

<!-- ── Connect modal ───────────────────────────────────────── -->
@if (_selectedAp is not null)
{
    <ConnectForm AccessPoint="@_selectedAp"
                 OnConnect="@HandleConnect"
                 OnCancel="@CloseConnectForm"
                 IsConnecting="@WifiService.IsConnecting"
                 ErrorMessage="@_connectError" />
}

@code {
    private WifiAccessPoint? _selectedAp;
    private string? _connectError;

    protected override async Task OnInitializedAsync()
    {
        WifiService.OnStateChanged += OnServiceStateChanged;
        if (!WifiService.IsInitialized)
            await WifiService.InitializeAsync();
    }

    private void OnServiceStateChanged()
        => InvokeAsync(StateHasChanged);

    private async Task HandleScan()
    {
        _connectError = null;
        await WifiService.ScanAsync();
    }

    private void ShowConnectForm(WifiAccessPoint ap)
    {
        _connectError = null;
        _selectedAp   = ap;
    }

    private void CloseConnectForm()
    {
        _selectedAp   = null;
        _connectError = null;
    }

    private async Task HandleConnect((string Password, string SecurityType) args)
    {
        if (_selectedAp is null) return;

        if (args.SecurityType != "Open" && string.IsNullOrWhiteSpace(args.Password))
        {
            _connectError = "Password is required for this network.";
            return;
        }

        _connectError = null;
        var success = await WifiService.ConnectAsync(_selectedAp, args.Password, args.SecurityType);
        if (success)
            CloseConnectForm();
        else
            _connectError = WifiService.LastError ?? "Connection failed.";
    }

    private async Task HandleDisconnect()
    {
        _connectError = null;
        await WifiService.DisconnectAsync();
    }

    // ── UI helpers ────────────────────────────────────────────

    private static string WifiIcon(int rssi) => rssi switch
    {
        >= 80 => "📶",
        >= 60 => "📶",
        >= 40 => "📶",
        _     => "📶"
    };

    private static string FrequencyBand(int freq)
        => freq >= 5000 ? "5 GHz" : "2.4 GHz";

    private static string RSSIColor(int rssi) => rssi switch
    {
        >= 80 => "#22c55e",
        >= 60 => "#84cc16",
        >= 40 => "#f59e0b",
        _     => "#ef4444"
    };

    private static string SecurityBadgeClass(string security) => security switch
    {
        "WPA3"  => "badge-green",
        "WPA2"  => "badge-blue",
        "WPA"   => "badge-blue",
        "WEP"   => "badge-orange",
        "Open"  => "badge-red",
        _       => "badge-gray"
    };

    public void Dispose()
    {
        WifiService.OnStateChanged -= OnServiceStateChanged;
    }
}
